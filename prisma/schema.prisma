generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  role            Role             @default(USER)
  accounts        Account[]
  sessions        Session[]
  watchlist       Watchlist[]
  artistRequests  ArtistRequest[]
  linkSuggestions LinkSuggestion[]
  modInvites      ModInvite[]
  modRequests     ModRequest[]
  createdAt       DateTime         @default(now())
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum Platform {
  YOUTUBE
  SPOTIFY
  TIKTOK
  INSTAGRAM
}

model Artist {
  id             String           @id @default(cuid())
  spotifyId      String?          @unique
  name           String
  imageUrl       String?
  bannerUrl      String?
  bio            String?
  genres         String[]         @default([])
  spotifyPopularity Int           @default(0)
  watchlistCount Int              @default(0)
  addedById      String
  links          ArtistLink[]
  watchlistedBy  Watchlist[]
  suggestions    LinkSuggestion[]
  requests       ArtistRequest[]
  snapshots      ArtistSnapshot[]
  rankSnapshots  RankSnapshot[]
  tracks         Track[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ArtistLink {
  id               String   @id @default(cuid())
  artistId         String
  platform         Platform
  url              String
  handle           String?
  followerCount    Int      @default(0)
  monthlyListeners Int      @default(0)
  platformId       String?
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([artistId, platform])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  artistId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ArtistRequest {
  id         String        @id @default(cuid())
  type       String        @default("ADD") // ADD or REMOVAL
  name       String
  links      String        @default("")
  artistId   String?
  reason     String?
  status     RequestStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  userId     String
  artist     Artist?       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model LinkSuggestion {
  id         String        @id @default(cuid())
  artistId   String
  platform   Platform
  url        String
  note       String?
  status     RequestStatus @default(PENDING)
  reviewedBy String?
  userId     String
  artist     Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ModInvite {
  id          String       @id @default(cuid())
  code        String       @unique
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  maxUses     Int          @default(1)
  usedCount   Int          @default(0)
  expiresAt   DateTime?
  active      Boolean      @default(true)
  requests    ModRequest[]
  createdAt   DateTime     @default(now())
}

model ModRequest {
  id         String        @id @default(cuid())
  userId     String
  inviteId   String
  status     RequestStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invite     ModInvite     @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([userId, inviteId])
}

model SiteSetting {
  id    String @id @default("singleton")
  key   String @unique
  value String
}

model ArtistSnapshot {
  id                   String   @id @default(cuid())
  artistId             String
  monthlyListeners     Int      @default(0)
  followerCount        Int      @default(0)
  youtubeSubscribers   Int      @default(0)
  tiktokFollowers      Int      @default(0)
  instagramFollowers   Int      @default(0)
  artist               Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@index([artistId, createdAt])
}

model RankSnapshot {
  id        String   @id @default(cuid())
  artistId  String
  rank      Int
  date      String
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([artistId, date])
  @@index([date])
}

model Track {
  id              String   @id @default(cuid())
  spotifyId       String   @unique
  artistId        String
  name            String
  albumName       String?
  albumImageUrl   String?
  previewUrl      String?
  durationMs      Int      @default(0)
  popularity      Int      @default(0)
  trackNumber     Int      @default(0)
  discNumber      Int      @default(0)
  explicit        Boolean  @default(false)
  releaseDate     String?
  spotifyUrl      String?
  featuredArtists String[] @default([])
  artist          Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([artistId, popularity(sort: Desc)])
}

model UpdateLog {
  id             String   @id @default(cuid())
  trigger        String   @default("manual") // manual | cron
  status         String   @default("running") // running | completed | failed
  totalArtists   Int      @default(0)
  updatedCount   Int      @default(0)
  failedCount    Int      @default(0)
  durationMs     Int      @default(0)
  details        String?  @db.Text // JSON array of per-artist results
  error          String?
  createdAt      DateTime @default(now())
  completedAt    DateTime?
}